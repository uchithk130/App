generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")


}

enum RoleCode {
  CUSTOMER
  ADMIN
  RIDER
}

enum OrderType {
  ONE_TIME
  SUBSCRIPTION
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  ASSIGNED
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUND_PENDING
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum SubscriptionScheduleStatus {
  SCHEDULED
  SKIPPED
  PAUSED
  FULFILLED
}

enum DietaryPreference {
  VEG
  VEGAN
  EGGETARIAN
  NON_VEG
  PESCATARIAN
  KETO
  PALEO
  HIGH_PROTEIN
  LOW_CARB
}

enum FitnessGoal {
  FAT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  PERFORMANCE
  GENERAL_HEALTH
}

enum RiderAvailability {
  OFFLINE
  AVAILABLE
  BUSY
}

enum RiderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum WalletTransactionType {
  CREDIT_DELIVERY
  ADJUSTMENT
  WITHDRAWAL_HOLD
  WITHDRAWAL_RELEASE
  REVERSAL
}

enum BankVerificationStatus {
  NOT_SUBMITTED
  PENDING_VERIFICATION
  VERIFICATION_IN_PROGRESS
  VERIFIED
  VERIFICATION_FAILED
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EditRequestType {
  PROFILE
  BANK_DETAILS
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  PRE_WORKOUT
  POST_WORKOUT
}

enum MealListingStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

enum CustomMealRequestStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED_TO_ORDER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Role {
  id        String       @id @default(cuid())
  code      RoleCode     @unique
  name      String
  users     UserOnRole[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum AppScope {
  CUSTOMER
  RIDER
  ADMIN
}

model User {
  id                  String               @id @default(cuid())
  email               String
  phone               String?
  passwordHash        String
  appScope            AppScope
  emailVerifiedAt     DateTime?
  roles               UserOnRole[]
  customerProfile     CustomerProfile?
  riderProfile        RiderProfile?
  adminProfile        AdminProfile?
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([email, appScope])
  @@index([email])
  @@index([createdAt])
  @@index([deletedAt])
}

model UserOnRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  userAgent    String?
  ip           String?
  expiresAt    DateTime
  revokedAt    DateTime?
  revokeReason String?
  lastSeenAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model CustomerProfile {
  id                 String                 @id @default(cuid())
  userId             String                 @unique
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName           String
  gender             String?
  dateOfBirth        DateTime?
  heightCm           Int?
  weightKg           Decimal?               @db.Decimal(6, 2)
  activityLevel      String?
  fitnessGoal        FitnessGoal?
  dietaryPreference  DietaryPreference?
  allergies          String?
  intolerances       String?
  healthNotes        String?
  preferredMealTimes String?
  dailyCalorieGoal   Int?
  targetProteinG     Int?
  targetCarbG        Int?
  targetFatG         Int?
  emergencyContact   String?
  deliveryNotes      String?
  addresses          Address[]
  carts              Cart[]
  favorites          FavoriteMeal[]
  reviews            Review[]
  supportTickets     SupportTicket[]
  subscriptions      CustomerSubscription[]
  customMealRequests CustomMealRequest[]
  notificationLogs   NotificationLog[]
  orders             Order[]
  couponUsages       CouponUsage[]
  couponTargets      CouponCustomer[]
  orderRatings       OrderRating[]
  driverRatings      DriverRating[]
  tips               TipTransaction[]
  postDeliveryFlows  PostDeliveryFlowState[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([userId])
}

model RiderProfile {
  id                 String               @id @default(cuid())
  userId             String               @unique
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName           String
  avatarUrl          String?
  emergencyContact   String?
  licenseNumber      String?
  address            String?
  isProfileCompleted Boolean              @default(false)
  availability       RiderAvailability    @default(OFFLINE)
  approvalStatus     RiderApprovalStatus  @default(PENDING)
  approvedAt         DateTime?
  rejectionReason    String?
  vehicleType        String?
  vehicleNumber      String?
  kycStatus          String?
  bankDetailsJson    Json?
  lastKnownLat       Decimal?             @db.Decimal(10, 7)
  lastKnownLng       Decimal?             @db.Decimal(10, 7)
  locationUpdatedAt  DateTime?
  wallet             Wallet?
  bankAccount        RiderBankAccount?
  editRequests       RiderEditRequest[]
  assignments        RiderAssignment[]
  driverRatings      DriverRating[]
  tips               TipTransaction[]
  notifications      NotificationLog[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([availability])
  @@index([approvalStatus])
}

model RiderBankAccount {
  id                        String                 @id @default(cuid())
  riderId                   String                 @unique
  rider                     RiderProfile           @relation(fields: [riderId], references: [id], onDelete: Cascade)
  accountHolderName         String
  maskedAccountNumber       String
  accountNumberEncrypted    String
  ifscCode                  String
  bankName                  String?
  upiId                     String?
  verificationStatus        BankVerificationStatus @default(NOT_SUBMITTED)
  verificationProvider      String?
  verificationReferenceId   String?
  verifiedAt                DateTime?
  approvedByAdminId         String?
  approvedAt                DateTime?
  isActive                  Boolean                @default(false)
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  @@index([verificationStatus])
}

model RiderEditRequest {
  id                        String                  @id @default(cuid())
  riderId                   String
  rider                     RiderProfile            @relation(fields: [riderId], references: [id], onDelete: Cascade)
  requestType               EditRequestType
  status                    EditRequestStatus       @default(PENDING)
  currentDataJson           Json?
  submittedDataJson         Json
  /// Bank-specific: masked account number for display
  maskedAccountNumber       String?
  /// Bank-specific: encrypted account number
  accountNumberEncrypted    String?
  /// Bank verification
  verificationStatus        BankVerificationStatus?
  verificationProvider      String?
  verificationReferenceId   String?
  verifiedAt                DateTime?
  /// Admin review
  reviewNotes               String?
  reviewedAt                DateTime?
  reviewedByAdminId         String?
  submittedAt               DateTime               @default(now())
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  @@index([riderId, requestType, status])
  @@index([status, requestType, createdAt])
}

model AdminProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceableZone {
  id               String          @id @default(cuid())
  name             String
  isActive         Boolean         @default(true)
  baseDeliveryFee  Decimal         @db.Decimal(10, 2)
  minOrderAmount   Decimal         @db.Decimal(10, 2)
  taxRatePercent   Decimal?        @db.Decimal(5, 2)
  pincodes         ZonePincode[]
  addresses        Address[]
  orders           Order[]
  slots            DeliverySlot[]
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([isActive])
}

model ZonePincode {
  id        String          @id @default(cuid())
  zoneId    String
  zone      ServiceableZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  pincode   String
  createdAt DateTime        @default(now())

  @@unique([zoneId, pincode])
  @@index([pincode])
}

model DeliverySlot {
  id                    String                 @id @default(cuid())
  zoneId                String?
  zone                  ServiceableZone?       @relation(fields: [zoneId], references: [id])
  label                 String
  startTime             DateTime
  endTime               DateTime
  capacity              Int                    @default(50)
  booked                Int                    @default(0)
  isActive              Boolean                @default(true)
  orders                Order[]
  subscriptionSchedules SubscriptionSchedule[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([zoneId, isActive])
}

/** Home screen promo carousel — admin-managed. */
model HomePromoBanner {
  id           String   @id @default(cuid())
  sortOrder    Int      @default(0)
  badge        String?
  headline     String
  subline      String?
  imageUrl     String?
  mealSlug     String?
  gradientFrom String   @default("#059669")
  gradientTo   String   @default("#34d399")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Address {
  id         String          @id @default(cuid())
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  zoneId     String?
  zone       ServiceableZone? @relation(fields: [zoneId], references: [id])
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  lat        Decimal?        @db.Decimal(9, 6)
  lng        Decimal?        @db.Decimal(9, 6)
  isDefault  Boolean         @default(false)
  label      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([customerId])
  @@index([pincode])
}

model MealCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  /** Optional icon image URL (admin upload or external). */
  iconUrl     String?
  meals       Meal[]
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, sortOrder])
}

model Meal {
  id          String       @id @default(cuid())
  categoryId  String
  category    MealCategory @relation(fields: [categoryId], references: [id])
  name        String
  slug        String       @unique
  description     String?
  mealType        MealType
  isActive        Boolean            @default(true)
  listingStatus   MealListingStatus  @default(ACTIVE)
  /** Shown on customer menu when enabled (admin toggles). */
  richInProtein   Boolean            @default(false)
  richInFiber     Boolean            @default(false)
  richInLowCarb   Boolean            @default(false)
  basePrice       Decimal            @db.Decimal(10, 2)
  /** Optional “was” price for offers / strike-through UI. */
  compareAtPrice  Decimal?           @db.Decimal(10, 2)
  images      MealImage[]
  nutrition   MealNutrition?
  cartItems   CartItem[]
  orderItems  OrderItem[]
  favorites   FavoriteMeal[]
  reviews     Review[]
  couponTargets CouponMeal[]
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([categoryId, isActive])
  @@index([mealType])
  @@index([isActive, createdAt])
}

model MealImage {
  id        String   @id @default(cuid())
  mealId    String
  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([mealId])
}

model MealNutrition {
  id        String   @id @default(cuid())
  mealId    String   @unique
  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  calories  Int
  proteinG  Decimal  @db.Decimal(6, 2)
  carbG     Decimal  @db.Decimal(6, 2)
  fatG      Decimal  @db.Decimal(6, 2)
  fiberG    Decimal  @db.Decimal(6, 2)
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id                String                 @id @default(cuid())
  name              String
  description       String?
  price             Decimal                @db.Decimal(10, 2)
  billingPeriodDays Int                    @default(7)
  isActive          Boolean                @default(true)
  rules             SubscriptionPlanRule[]
  subscriptions     CustomerSubscription[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([isActive])
}

model SubscriptionPlanRule {
  id               String           @id @default(cuid())
  planId           String
  plan             SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  mealsPerWeek     Int
  deliveryDaysMask String
  macroTargetsJson Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([planId])
}

model CustomerSubscription {
  id                 String                 @id @default(cuid())
  customerId         String
  customer           CustomerProfile        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  planId             String
  plan               SubscriptionPlan       @relation(fields: [planId], references: [id])
  status             SubscriptionStatus     @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  pauseReason        String?
  schedules          SubscriptionSchedule[]
  subscriptionOrders SubscriptionOrder[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([customerId, status])
  @@index([status, currentPeriodEnd])
}

model SubscriptionSchedule {
  id               String                     @id @default(cuid())
  subscriptionId   String
  subscription     CustomerSubscription       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  scheduledFor     DateTime
  slotId           String?
  slot             DeliverySlot?              @relation(fields: [slotId], references: [id])
  status           SubscriptionScheduleStatus @default(SCHEDULED)
  generatedOrderId String?                    @unique
  generatedOrder   Order?                     @relation("ScheduleGeneratedOrder", fields: [generatedOrderId], references: [id])
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([subscriptionId, scheduledFor])
  @@index([scheduledFor, status])
}

model SubscriptionOrder {
  id             String               @id @default(cuid())
  subscriptionId String
  subscription   CustomerSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  orderId        String               @unique
  order          Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sequenceNo     Int
  createdAt      DateTime             @default(now())

  @@index([subscriptionId])
}

model Cart {
  id         String      @id @default(cuid())
  customerId String      @unique
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]
  updatedAt  DateTime    @updatedAt
  createdAt  DateTime    @default(now())
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  mealId    String
  meal      Meal     @relation(fields: [mealId], references: [id])
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
}

model Order {
  id                 String              @id @default(cuid())
  customerId         String
  customer           CustomerProfile     @relation(fields: [customerId], references: [id])
  type               OrderType
  status             OrderStatus         @default(PENDING_PAYMENT)
  zoneId             String
  zone               ServiceableZone     @relation(fields: [zoneId], references: [id])
  addressSnapshot    Json
  slotId             String?
  slot               DeliverySlot?       @relation(fields: [slotId], references: [id])
  subtotal           Decimal             @db.Decimal(10, 2)
  deliveryFee        Decimal             @db.Decimal(10, 2)
  tax                Decimal             @db.Decimal(10, 2)
  discount           Decimal             @db.Decimal(10, 2) @default(0)
  total              Decimal             @db.Decimal(10, 2)
  payment            Payment?
  items              OrderItem[]
  subscriptionLink   SubscriptionOrder?
  assignment         RiderAssignment?
  statusLogs         DeliveryStatusLog[]
  reviews            Review[]
  orderRating        OrderRating?
  driverRating       DriverRating?
  tips               TipTransaction[]
  postDeliveryFlow   PostDeliveryFlowState?
  couponUsages       CouponUsage[]
  customRequestId    String?             @unique
  customRequest      CustomMealRequest?  @relation(fields: [customRequestId], references: [id])
  generatedFromSchedule SubscriptionSchedule? @relation("ScheduleGeneratedOrder")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([customerId, status, createdAt])
  @@index([status, createdAt])
  @@index([zoneId, status])
  @@index([type, status])
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  mealId            String
  meal              Meal     @relation(fields: [mealId], references: [id])
  quantity          Int
  unitPrice         Decimal  @db.Decimal(10, 2)
  nutritionSnapshot Json?
  createdAt         DateTime @default(now())

  @@index([orderId])
  @@index([mealId])
}

model Payment {
  id                  String        @id @default(cuid())
  orderId             String        @unique
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider            String        @default("RAZORPAY")
  providerOrderId     String?       @unique
  providerPaymentId   String?       @unique
  status              PaymentStatus @default(PENDING)
  method              String?
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("INR")
  rawPayload          Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status, createdAt])
}

model Coupon {
  id                      String            @id @default(cuid())
  code                    String            @unique
  title                   String?
  description             String?
  percentOff              Decimal?          @db.Decimal(5, 2)
  amountOff               Decimal?          @db.Decimal(10, 2)
  freeShipping            Boolean           @default(false)
  maxDiscount             Decimal?          @db.Decimal(10, 2)
  minOrderAmount          Decimal?          @db.Decimal(10, 2)
  maxUses                 Int?
  perUserLimit            Int?
  usedCount               Int               @default(0)
  validFrom               DateTime?
  expiresAt               DateTime?
  isActive                Boolean           @default(true)
  appliesToAllCustomers   Boolean           @default(true)
  appliesToAllMeals       Boolean           @default(true)
  firstOrderOnly          Boolean           @default(false)
  termsAndConditions      String?
  displayBadge            String?
  sortOrder               Int               @default(0)
  deletedAt               DateTime?
  usages                  CouponUsage[]
  targetedCustomers       CouponCustomer[]
  targetedMeals           CouponMeal[]
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([isActive, expiresAt])
  @@index([sortOrder])
}

model CouponCustomer {
  couponId   String
  customerId String
  coupon     Coupon          @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([couponId, customerId])
  @@index([customerId])
}

model CouponMeal {
  couponId String
  mealId   String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  meal     Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@id([couponId, mealId])
  @@index([mealId])
}

model CouponUsage {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([couponId, orderId])
  @@index([customerId])
}

model Review {
  id         String          @id @default(cuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  mealId     String
  meal       Meal            @relation(fields: [mealId], references: [id])
  rating     Int
  comment    String?
  isVisible  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([orderId, mealId])
  @@index([mealId, isVisible])
}

model OrderRating {
  id         String          @id @default(cuid())
  orderId    String          @unique
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([customerId])
}

model DriverRating {
  id         String          @id @default(cuid())
  orderId    String          @unique
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  riderId    String
  rider      RiderProfile    @relation(fields: [riderId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([riderId])
  @@index([customerId])
}

model TipTransaction {
  id               String          @id @default(cuid())
  orderId          String
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId       String
  customer         CustomerProfile @relation(fields: [customerId], references: [id])
  riderId          String
  rider            RiderProfile    @relation(fields: [riderId], references: [id])
  amount           Decimal         @db.Decimal(10, 2)
  currency         String          @default("INR")
  status           String          @default("initiated")
  paymentReference String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([orderId, customerId])
  @@index([riderId])
}

model PostDeliveryFlowState {
  id               String          @id @default(cuid())
  orderId          String          @unique
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId       String
  customer         CustomerProfile @relation(fields: [customerId], references: [id])
  successModalSeen Boolean         @default(false)
  orderRated       Boolean         @default(false)
  driverRated      Boolean         @default(false)
  tipHandled       Boolean         @default(false)
  mealsRated       Boolean         @default(false)
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([customerId])
}

model FavoriteMeal {
  customerId String
  mealId     String
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  meal       Meal            @relation(fields: [mealId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@id([customerId, mealId])
}

model SupportTicket {
  id         String              @id @default(cuid())
  customerId String
  customer   CustomerProfile     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subject    String
  body       String
  status     SupportTicketStatus @default(OPEN)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([customerId, status])
}

model CustomMealRequest {
  id             String                  @id @default(cuid())
  customerId     String
  customer       CustomerProfile         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status         CustomMealRequestStatus @default(SUBMITTED)
  mealType       MealType
  targetCalories Int?
  targetProteinG Int?
  targetCarbG    Int?
  targetFatG     Int?
  targetFiberG   Int?
  exclusions     String?
  quantity       Int                     @default(1)
  notes          String?
  adminPrice     Decimal?                @db.Decimal(10, 2)
  adminNote      String?
  order          Order?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([customerId, status])
  @@index([status, createdAt])
}

model RiderAssignment {
  id                String       @id @default(cuid())
  orderId           String       @unique
  order             Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  riderId           String
  rider             RiderProfile @relation(fields: [riderId], references: [id])
  assignedByAdminId String?
  assignedAt        DateTime     @default(now())
  unassignedAt      DateTime?

  @@index([riderId, assignedAt])
}

model DeliveryStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  meta      Json?
  createdAt DateTime    @default(now())

  @@index([orderId, createdAt])
}

model Wallet {
  id           String              @id @default(cuid())
  riderId      String              @unique
  rider        RiderProfile        @relation(fields: [riderId], references: [id], onDelete: Cascade)
  balance      Decimal             @db.Decimal(12, 2) @default(0)
  heldBalance  Decimal             @db.Decimal(12, 2) @default(0)
  txs          WalletTransaction[]
  withdrawals  WithdrawalRequest[]
  updatedAt    DateTime            @updatedAt
  createdAt    DateTime            @default(now())
}

model WalletTransaction {
  id        String                @id @default(cuid())
  walletId  String
  wallet    Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type      WalletTransactionType
  amount    Decimal               @db.Decimal(12, 2)
  reference String?
  meta      Json?
  createdAt DateTime              @default(now())

  @@index([walletId, createdAt])
  @@index([type, createdAt])
}

model WithdrawalRequest {
  id             String           @id @default(cuid())
  walletId       String
  wallet         Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount         Decimal          @db.Decimal(12, 2)
  status         WithdrawalStatus @default(PENDING)
  bankAccountId  String?
  bankRef        String?
  adminNote      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([walletId, status])
  @@index([status, createdAt])
}

model NotificationLog {
  id          String           @id @default(cuid())
  channel     String
  template    String
  payload     Json
  status      String
  customerId  String?
  customer    CustomerProfile? @relation(fields: [customerId], references: [id])
  riderId     String?
  rider       RiderProfile?    @relation(fields: [riderId], references: [id])
  error       String?
  createdAt   DateTime         @default(now())

  @@index([channel, status, createdAt])
  @@index([riderId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
}

model Banner {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  href      String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
}
