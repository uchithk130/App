# Local development only — copy to `.env` and set real values. Never commit `.env`.

# PostgreSQL (example: postgresql://USER:PASSWORD@localhost:5432/fitmeals_dev?schema=public)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitmeals_dev?schema=public"

# API (apps/api) — used for JWT signing and cookie configuration
JWT_ACCESS_SECRET="change-me-access-min-32-chars-dev-only"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars-dev-only"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# For cross-subdomain cookies in production, set e.g. .yourdomain.com; leave empty for localhost
AUTH_COOKIE_DOMAIN=
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
NEXT_PUBLIC_RIDER_URL="http://localhost:3002"
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Local dev: apps on different ports cannot share API cookies — return refresh token in JSON for SPA storage
AUTH_RETURN_REFRESH_BODY="true"

# AWS S3 (meal images) — optional for local; use mock or real bucket
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
# Public URL prefix for meal images (e.g. https://your-bucket.s3.ap-south-1.amazonaws.com or CloudFront)
S3_PUBLIC_BASE_URL=""

# Razorpay — optional for local; E2E mocks verification
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# WhatsApp — leave empty to use mock provider
WHATSAPP_PROVIDER="mock"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
